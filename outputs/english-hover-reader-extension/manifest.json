{
  "manifest_version": 3,
  "name": "English Hover Reader",
  "version": "1.2.1",
  "description": "Select English words or sentences, right-click to look up words or translate sentences, and keep a review library.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.dictionaryapi.dev/*",
    "https://dict.youdao.com/*",
    "https://api.mymemory.translated.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "contentScript.js"
      ],
      "css": [
        "contentStyles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "English Hover Reader",
    "default_popup": "popup.html"
  },
  "options_page": "library.html"
}
