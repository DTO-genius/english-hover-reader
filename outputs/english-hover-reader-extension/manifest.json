{
  "manifest_version": 3,
  "name": "English Hover Reader",
  "version": "1.1.0",
  "description": "Hover over English words to see IPA, Chinese meaning, simple examples, English definitions, audio, and an automatic vocabulary book.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.dictionaryapi.dev/*",
    "https://dict.youdao.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "contentScript.js"
      ],
      "css": [
        "contentStyles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "English Hover Reader",
    "default_popup": "popup.html"
  }
}
